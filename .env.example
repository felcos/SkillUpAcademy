# =============================================
# Variables de entorno para producción
# Copiar a .env y rellenar con valores reales
# NUNCA commitear el archivo .env
# =============================================

# Base de datos
POSTGRES_PASSWORD=
CONNECTION_STRING=Host=db;Port=5432;Database=skillup_academy;Username=postgres;Password=TU_PASSWORD_SEGURO

# JWT (mínimo 64 caracteres, usar generador seguro)
JWT_SECRET=

# Anthropic (IA)
ANTHROPIC_API_KEY=

# Azure TTS (opcional — dejar vacío si se usa WebSpeechApi)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westeurope

# CORS — orígenes permitidos separados por coma
CORS_ORIGINS=https://tudominio.com
