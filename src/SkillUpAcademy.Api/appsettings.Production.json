{
  "ConnectionStrings": {
    "DefaultConnection": "Host=db;Port=5432;Database=skillup_academy;Username=postgres;Password=${POSTGRES_PASSWORD}"
  },
  "Jwt": {
    "Secret": "CAMBIAR_ESTA_CLAVE_SECRETA_EN_PRODUCCION_DEBE_SER_DE_64_CARACTERES_MINIMO_USAR_ENV_VAR",
    "Issuer": "SkillUpAcademy",
    "Audience": "SkillUpAcademy"
  },
  "Anthropic": {
    "ApiKey": ""
  },
  "Tts": {
    "AzureSpeechKey": "",
    "AzureSpeechRegion": ""
  },
  "Cors": {
    "OrigenesPermitidos": [ "https://tudominio.com" ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "SkillUpAcademy": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "/app/logs/skillup-academy-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 10485760
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
